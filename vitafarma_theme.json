{
  "name": "VitaFarma Dark",
  "dataColors": [
    "#00C49F",
    "#FF6B6B",
    "#4ECDC4",
    "#FFE66D",
    "#A29BFE",
    "#FD79A8",
    "#6C5CE7",
    "#00B894"
  ],
  "background": "#0F1117",
  "foreground": "#1C1F26",
  "tableAccent": "#00C49F",
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#1C1F26" } } }],
        "border": [{ "show": false }],
        "title": [{
          "fontColor": { "solid": { "color": "#E8E8E8" } },
          "fontSize": 13,
          "fontFamily": "Segoe UI"
        }]
      }
    },
    "card": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#1C1F26" } } }],
        "dataLabels": [{
          "color": { "solid": { "color": "#00C49F" } },
          "fontSize": 28
        }],
        "categoryLabels": [{
          "color": { "solid": { "color": "#A0A0A0" } },
          "fontSize": 11
        }]
      }
    },
    "barChart": {
      "*": {
        "categoryAxis": [{
          "labelColor": { "solid": { "color": "#E8E8E8" } },
          "fontSize": 11
        }],
        "valueAxis": [{
          "labelColor": { "solid": { "color": "#A0A0A0" } },
          "gridlineColor": { "solid": { "color": "#2A2D35" } }
        }],
        "dataLabels": [{
          "color": { "solid": { "color": "#E8E8E8" } }
        }]
      }
    },
    "lineChart": {
      "*": {
        "categoryAxis": [{
          "labelColor": { "solid": { "color": "#E8E8E8" } }
        }],
        "valueAxis": [{
          "labelColor": { "solid": { "color": "#A0A0A0" } },
          "gridlineColor": { "solid": { "color": "#2A2D35" } }
        }]
      }
    },
    "donutChart": {
      "*": {
        "legend": [{
          "labelColor": { "solid": { "color": "#E8E8E8" } }
        }],
        "dataLabels": [{
          "color": { "solid": { "color": "#E8E8E8" } }
        }]
      }
    },
    "slicer": {
      "*": {
        "data": [{
          "fontColor": { "solid": { "color": "#E8E8E8" } },
          "background": { "solid": { "color": "#1C1F26" } }
        }],
        "header": [{
          "fontColor": { "solid": { "color": "#00C49F" } },
          "background": { "solid": { "color": "#1C1F26" } }
        }],
        "items": [{
          "fontColor": { "solid": { "color": "#E8E8E8" } },
          "background": { "solid": { "color": "#1C1F26" } }
        }]
      }
    }
  }
}
